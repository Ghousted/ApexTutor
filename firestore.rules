rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Per-user data ──────────────────────────────────────────────────
    // Profile, subscription, sessions, messages, lesson progress.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // Legacy per-lesson progress (kept for back-compat).
      match /lessons/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // NEW — course enrollment + linear lesson progress.
      // users/{uid}/enrollments/{courseId} stores lastStepIndex, completedLessonIds, etc.
      match /enrollments/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ─── Course catalog — read-only for signed-in students ──────────────
    // Admin writes go through the Admin SDK (bypasses rules). Students
    // need to read courses + lessons to browse and play them.
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /lessons/{lessonId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ─── Admin-published config — read by all signed-in users ──────────
    // Admins write these docs via the Admin SDK (server-side routes only).
    // Clients can read so the configured values (e.g., instructor avatar
    // overrides) take effect across all sessions without a redeploy.
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Textbook RAG data — server-only ────────────────────────────────
    // instructorDocs/{instructorId}/sources/*
    // instructorDocs/{instructorId}/chunks/*
    //
    // All reads + writes go through the admin SDK (chat /api/chat and the
    // /api/admin/textbooks/* routes), which BYPASSES these rules. Blocking
    // direct client access is defense-in-depth: prevents anyone snooping
    // the embeddings or wiping content from a browser console.
    match /instructorDocs/{document=**} {
      allow read, write: if false;
    }
  }
}
